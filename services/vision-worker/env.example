# Copy to .env (never commit .env). Use Supabase service_role only on the server.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Builder auth.users.id who should receive insights in the app
VISION_USER_ID=00000000-0000-0000-0000-000000000000

# Primary camera (IP cam / NVR substream). Substream = lower res saves CPU.
RTSP_URL=rtsp://user:pass@192.168.1.100:554/stream1

# Optional — improves filtering in Project / Monitoring UIs
# PROJECT_ID=
# MONITORING_REQUEST_ID=
CAMERA_LABEL=Gate cam
# SOURCE_STREAM_ID=

# Tunables
ANALYSIS_INTERVAL_SEC=2
INSIGHT_MIN_INTERVAL_SEC=45
YOLO_MODEL=yolov8n.pt
CONFIDENCE=0.35
# cpu | cuda:0 (only if GPU + NVIDIA drivers on host)
YOLO_DEVICE=cpu
