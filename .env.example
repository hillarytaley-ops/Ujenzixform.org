# Copy to .env.local for local overrides (never commit real secrets).

# --- Site URL (OAuth redirect + meta tags) ---
# Pre-launch (Vercel): stable production host — not ephemeral preview URLs (see VERCEL_DOMAINS_EXPLAINED.md).
VITE_PUBLIC_SITE_URL=https://ujenzi-pro.vercel.app
# After go-live on custom domain:
# VITE_PUBLIC_SITE_URL=https://ujenzixform.org

# --- Security ---
# Production builds always require a Supabase JWT for the admin dashboard UI.
# Set explicitly in local dev to match production behavior:
# VITE_REQUIRE_SUPABASE_SESSION_FOR_ADMIN=true

# Allow hardcoded super-admin bootstrap credentials in production builds (discouraged).
# VITE_ALLOW_SUPER_ADMIN_FALLBACK=false

# --- Observability (recommended for production) ---
# https://sentry.io — create a React project and paste the DSN (Vercel: Project → Settings → Environment Variables).
# VITE_SENTRY_DSN=
# Optional: send Sentry events from local/dev builds while testing.
# VITE_SENTRY_DEBUG=false

# App version string for Sentry releases (optional).
# VITE_APP_VERSION=2.0.1

# --- Admin Documents tab: marketing QR codes (optional) ---
# Default is https://www.ujenzixform.org. Set to http://localhost:5173 (or your preview URL) to generate QRs for that host.
# VITE_QR_LINK_BASE_URL=https://www.ujenzixform.org

# --- /auth “Staff access” link (optional extras) ---
# Primary source: active emails in Supabase admin_staff (Admin → Staff). RPC: is_admin_staff_portal_email.
# Optional domain shortcut (comma-separated; @ optional). Omit entirely to disable domain-only matching.
# VITE_STAFF_EMAIL_DOMAINS=ujenzixform.org
# Extra full emails (comma-separated) not in admin_staff but should still see Staff access.
# VITE_STAFF_EMAIL_ALLOWLIST=

# --- Public contact (optional overrides; Footer + Contact page) ---
# VITE_SUPPORT_PHONE_PRIMARY_TEL=+254715612073
# VITE_SUPPORT_PHONE_PRIMARY_DISPLAY=+254 715 612073
# VITE_SUPPORT_PHONE_SECONDARY_TEL=+254733987654
# VITE_SUPPORT_PHONE_SECONDARY_DISPLAY=+254 733 987 654
