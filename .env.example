# Copy to .env.local for local overrides (never commit real secrets).

# --- Security (optional) ---
# Require a Supabase JWT to open the admin dashboard UI (disables staff-only localStorage shell).
# VITE_REQUIRE_SUPABASE_SESSION_FOR_ADMIN=true

# Allow hardcoded super-admin bootstrap credentials in production builds (discouraged).
# VITE_ALLOW_SUPER_ADMIN_FALLBACK=false
