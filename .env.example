# Copy to .env.local for local overrides (never commit real secrets).

# --- Security (optional) ---
# Require a Supabase JWT to open the admin dashboard UI (disables staff-only localStorage shell).
# VITE_REQUIRE_SUPABASE_SESSION_FOR_ADMIN=true

# Allow hardcoded super-admin bootstrap credentials in production builds (discouraged).
# VITE_ALLOW_SUPER_ADMIN_FALLBACK=false

# --- Observability (recommended for production) ---
# https://sentry.io — create a React project and paste the DSN (Vercel: Project → Settings → Environment Variables).
# VITE_SENTRY_DSN=
# Optional: send Sentry events from local/dev builds while testing.
# VITE_SENTRY_DEBUG=false

# App version string for Sentry releases (optional).
# VITE_APP_VERSION=2.0.1

# --- Public contact (optional overrides; Footer + Contact page) ---
# VITE_SUPPORT_PHONE_PRIMARY_TEL=+254726749849
# VITE_SUPPORT_PHONE_PRIMARY_DISPLAY=+254 726 749 849
# VITE_SUPPORT_PHONE_SECONDARY_TEL=+254733987654
# VITE_SUPPORT_PHONE_SECONDARY_DISPLAY=+254 733 987 654
