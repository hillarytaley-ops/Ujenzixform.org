# Copy to .env — never commit .env (contains secrets)

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Project Settings → API → service_role (server only — not VITE / not browser)
SUPABASE_SERVICE_ROLE_KEY=

# Seconds between full polling cycles (all cameras once per cycle)
SAMPLE_INTERVAL_SEC=5

# Mean pixel difference (0–255 scale after blur) to emit a motion event
MOTION_THRESHOLD=25

# Minimum seconds between same (camera_id, event_type) inserts
MIN_EVENT_GAP_SEC=20

# 1 = run Ultralytics YOLO (install ultralytics in requirements first)
USE_YOLO=0
YOLO_MODEL=yolov8n.pt

# Identifies rows in site_vision_events.source_worker
SOURCE_WORKER=site-vision-python-v1
