  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-favicon.mjs && vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "check:auth-keys": "node scripts/check-legacy-supabase-auth-key.mjs",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:run": "vitest run",
    "favicon:generate": "node scripts/generate-favicon.mjs",
    "images:optimize": "node scripts/optimize-images.mjs",
    "db:analyze": "node scripts/consolidate-migrations.mjs --analyze",
    "db:consolidate": "node scripts/consolidate-migrations.mjs --generate",
    "db:archive": "node scripts/consolidate-migrations.mjs --archive",
    "db:lint-migrations": "node scripts/check-migration-security.mjs",
    "db:copy-migration-sql": "node scripts/copy-migration-clipboard.mjs",
    "db:copy-monitoring-sql": "node scripts/copy-migration-clipboard.mjs",
    "db:combine-migrations": "node scripts/combine-migrations.mjs",
    "security:audit": "npm audit --audit-level moderate",
    "security:test": "npm run lint && npm run check:auth-keys && npm run db:lint-migrations && npm run security:audit",
    "security:headers": "node scripts/test-security-headers.js",
    "security:secrets": "npx trufflehog filesystem . --json --only-verified",
    "security:licenses": "npx license-checker --onlyAllow 'MIT;ISC;BSD-2-Clause;BSD-3-Clause;Apache-2.0;Unlicense;CC0-1.0' --excludePrivatePackages",
    "security:full": "npm run security:test && npm run security:headers && npm run security:secrets && npm run security:licenses",
    "security:ci": "npm run security:full --silent",
    "mobile:sync": "npx cap sync",
    "mobile:android": "npm run build && npx cap sync android && npx cap open android",
    "mobile:ios": "npm run build && npx cap sync ios && npx cap open ios",
    "mobile:build:android": "npm run build && npx cap sync android",
    "mobile:build:ios": "npm run build && npx cap sync ios",
    "supabase:login": "supabase login",
    "supabase:link": "supabase link",
    "supabase:deploy-send-sms": "supabase functions deploy send-sms",
    "supabase:deploy-camera-vision-upload-ticket": "supabase functions deploy camera-vision-upload-ticket",
    "email:templates": "node scripts/email-templates.mjs build",
    "email:templates:preview": "node scripts/email-templates.mjs preview"
