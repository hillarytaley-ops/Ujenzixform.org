{
  "name": "mradipro",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:run": "vitest run",
    "images:optimize": "node scripts/optimize-images.mjs",
    "db:analyze": "node scripts/consolidate-migrations.mjs --analyze",
    "db:consolidate": "node scripts/consolidate-migrations.mjs --generate",
    "db:archive": "node scripts/consolidate-migrations.mjs --archive",
    "security:audit": "npm audit --audit-level moderate",
    "security:test": "npm run lint && npm run security:audit",
    "security:headers": "node scripts/test-security-headers.js",
    "security:secrets": "npx trufflehog filesystem . --json --only-verified",
    "security:licenses": "npx license-checker --onlyAllow 'MIT;ISC;BSD-2-Clause;BSD-3-Clause;Apache-2.0;Unlicense;CC0-1.0' --excludePrivatePackages",
    "security:full": "npm run security:test && npm run security:headers && npm run security:secrets && npm run security:licenses",
    "security:ci": "npm run security:full --silent"
  },
